# Per-merchant identity
XPAY_MERCHANT_SLUG=acme-outdoors
SITE_URL=https://store.acme.example/
SITE_NAME=Acme Outdoors
SITE_DESCRIPTION=Climbing gear and trail food

# Shared HS256 secret for cart-deeplink JWTs
# Get from your xpay merchant account: app.xpay.sh/onboard/prestashop
XPAY_API_KEY=xpay_live_REPLACE_ME

# PrestaShop Webservice API
# Auth: API key as HTTP basic auth (username = key, password empty)
# Enable in: Advanced Parameters → Webservice → Add new webservice key
# Required resources: products (GET), carts (GET/POST/PUT), orders (GET),
#                     customers (GET), addresses (GET)
PRESTASHOP_BASE_URL=https://store.acme.example
PRESTASHOP_API_KEY=REPLACE_WITH_API_KEY
# Language and shop ids — defaults are 1
PRESTASHOP_LANGUAGE_ID=1
PRESTASHOP_SHOP_ID=1

# Optional
HOST=0.0.0.0
PORT=8787
CHECKOUT_PATH=/checkout
EMIT_OAUTH_PROTECTED_RESOURCE=0
EMIT_AGENT_CARD=0
